# Datenbank
DATABASE_URL=postgresql+asyncpg://prowin:prowin_dev@localhost:5432/prowin

# MinIO / S3-kompatibel (lokal: MinIO, prod: Hetzner Object Storage)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin_dev
S3_BUCKET_NAME=prowin-belege
S3_REGION=eu-central-1

# Provider-Auswahl (stub | meta)
WHATSAPP_PROVIDER=stub
OCR_PROVIDER=stub
LLM_PROVIDER=stub

# WhatsApp Meta Cloud API (nur wenn WHATSAPP_PROVIDER=meta)
# Alle Werte aus dem Meta Developer Dashboard / Business Manager.
WHATSAPP_VERIFY_TOKEN=           # Frei wählbar — identisch im Meta-Dashboard eintragen
WHATSAPP_APP_SECRET=             # Meta App → Einstellungen → App-Geheimnis (für HMAC-Signaturprüfung)
WHATSAPP_ACCESS_TOKEN=           # Business Settings → System Users → permanenter Token
WHATSAPP_PHONE_NUMBER_ID=        # WhatsApp → Getting Started → Phone Number ID
WHATSAPP_GRAPH_VERSION=v21.0     # Graph-API-Version (aktuell v21.0)

# Mistral API (für OCR_PROVIDER=live und LLM_PROVIDER=live — gleicher API-Key)
MISTRAL_API_KEY=                     # https://console.mistral.ai → API Keys
MISTRAL_API_BASE_URL=https://api.mistral.ai/v1
OCR_MODEL=mistral-ocr-latest         # Mistral OCR 4
LLM_MODEL=mistral-small-latest       # Mistral Small (Beleg-Klassifikation)
# INTENT_MODEL=                      # Leer = LLM_MODEL. Für den Frage-Agenten kann
                                     # hier ein stärkeres Modell gesetzt werden
                                     # (z.B. mistral-medium-latest) ohne Code-Änderung.

# App
SECRET_KEY=change-this-in-production
DEBUG=false
LOG_LEVEL=info
